<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>PracDi Monetizable Card Builder</title>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/qrcodejs/1.0.0/qrcode.min.js"></script>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700&family=Poppins:wght@400;600;700&family=Montserrat:wght@400;600;700&family=Playfair+Display:wght@400;700&family=Roboto:wght@400;700&display=swap" rel="stylesheet">
  <style>
    :root{
      --bg:#eef1f6;
      --card:#ffffff;
      --text:#102542;
      --muted:#66758a;
      --border:#d8dee8;
      --primary:#3167e3;
      --primary-dark:#244fb8;
      --soft:#eef3ff;
      --header-grad:linear-gradient(135deg,#6d7cff,#8f5cff);
      --sponsor-grad:linear-gradient(90deg,#ffb347,#ffd86f);
      --preview-bg:linear-gradient(135deg,#6d7cff,#8f5cff);
    }

    *{box-sizing:border-box}
    body{
      margin:0;
      padding:16px;
      background:var(--bg);
      font-family:Inter, Arial, sans-serif;
      color:var(--text);
    }
    .wrap{
      max-width:1200px;
      margin:0 auto;
      display:grid;
      grid-template-columns: 420px 1fr;
      gap:18px;
    }
    .panel, .preview-shell{
      background:#fff;
      border-radius:24px;
      padding:18px;
      box-shadow:0 0 0 1px rgba(0,0,0,.04);
    }
    h1,h2,h3{
      margin:0 0 12px 0;
    }
    .panel h1{
      font-size:26px;
    }
    .sub{
      color:var(--muted);
      font-size:14px;
      margin-bottom:14px;
    }
    .section{
      border-top:1px solid var(--border);
      padding-top:14px;
      margin-top:14px;
    }
    .label{
      display:block;
      font-size:13px;
      color:var(--muted);
      margin-bottom:6px;
    }
    input, select, textarea{
      width:100%;
      border:1px solid #ccd5e3;
      border-radius:14px;
      padding:12px 14px;
      font-size:14px;
      background:#fff;
      margin-bottom:10px;
    }
    textarea{
      min-height:80px;
      resize:vertical;
    }
    .grid-2{
      display:grid;
      grid-template-columns:1fr 1fr;
      gap:10px;
    }
    .btn{
      border:none;
      border-radius:14px;
      padding:12px 14px;
      cursor:pointer;
      font-size:15px;
    }
    .btn-primary{
      background:var(--primary);
      color:#fff;
    }
    .btn-light{
      background:#eef2ff;
      color:var(--text);
      border:1px solid #bfd0ff;
    }
    .btn-row{
      display:grid;
      grid-template-columns:1fr 1fr;
      gap:10px;
    }

    /* preview */
    .preview-shell{
      background:var(--preview-bg);
      min-height:760px;
    }
    .preview-topbar{
      color:#fff;
      font-size:12px;
      text-align:center;
      margin-bottom:12px;
      opacity:.95;
    }
    .card-preview{
      max-width:420px;
      margin:0 auto;
      background:#fff;
      border-radius:26px;
      overflow:hidden;
      box-shadow:0 16px 28px rgba(0,0,0,.18);
    }
    .card-page{
      display:none;
      padding:18px;
    }
    .card-page.active{
      display:block;
    }

    .hero{
      background:var(--header-grad);
      color:#fff;
      border-radius:20px;
      padding:18px;
      display:grid;
      grid-template-columns:110px 1fr;
      gap:14px;
      align-items:center;
    }
    .logo-box{
      width:110px;
      height:110px;
      border-radius:22px;
      background:#f3f3f3;
      display:flex;
      align-items:center;
      justify-content:center;
      overflow:hidden;
      color:#444;
      font-size:13px;
      text-align:center;
    }
    .logo-box img{
      width:100%;
      height:100%;
      object-fit:cover;
    }
    .title-box h2{
      margin:0 0 6px 0;
      font-size:30px;
      line-height:1.02;
    }
    .title-box .job{
      font-size:16px;
      opacity:.95;
      margin-bottom:4px;
    }
    .title-box .company{
      font-size:13px;
      opacity:.85;
    }

    .quick-grid{
      margin-top:14px;
      display:grid;
      grid-template-columns:1fr 1fr;
      gap:12px;
    }
    .quick-box{
      background:#fff;
      border:1px solid var(--border);
      border-radius:18px;
      min-height:96px;
      display:flex;
      flex-direction:column;
      align-items:center;
      justify-content:center;
      padding:10px;
      text-align:center;
    }
    .quick-action{
      text-decoration:none;
      background:var(--primary);
      color:#fff;
      padding:10px 14px;
      border-radius:12px;
      display:inline-block;
      font-weight:600;
    }
    .qr-wrap{
      display:flex;
      flex-direction:column;
      align-items:center;
      justify-content:center;
      gap:6px;
    }
    .qr-box{
      width:86px;
      height:86px;
      display:flex;
      align-items:center;
      justify-content:center;
      background:#fff;
    }

    .sponsor-box{
      margin-top:14px;
      border-radius:16px;
      background:var(--sponsor-grad);
      min-height:74px;
      display:grid;
      grid-template-columns:80px 1fr;
      gap:10px;
      align-items:center;
      padding:10px 12px;
      color:#111;
    }
    .sponsor-logo{
      width:68px;
      height:68px;
      background:#fff;
      border-radius:14px;
      overflow:hidden;
      display:flex;
      align-items:center;
      justify-content:center;
      font-size:11px;
      text-align:center;
    }
    .sponsor-logo img{
      width:100%;
      height:100%;
      object-fit:cover;
    }
    .sponsor-text{
      font-weight:600;
      font-size:14px;
      line-height:1.25;
    }

    .nav{
      display:flex;
      gap:10px;
      justify-content:center;
      padding:14px 0 4px 0;
    }
    .nav button{
      border:none;
      border-radius:999px;
      padding:8px 12px;
      cursor:pointer;
      background:#eef2ff;
      color:var(--text);
    }

    .info-list{
      display:grid;
      gap:10px;
    }
    .info-item{
      border:1px solid var(--border);
      border-radius:16px;
      padding:12px 14px;
      background:#fbfcff;
    }
    .info-item b{
      display:block;
      margin-bottom:4px;
    }

    .page-head{
      font-size:24px;
      text-align:center;
      margin-bottom:14px;
    }

    .flipbook-card{
      border:1px solid var(--border);
      border-radius:18px;
      padding:18px;
      background:#fbfcff;
      text-align:center;
    }
    .flipbook-note{
      color:var(--muted);
      font-size:14px;
      margin:8px 0 14px 0;
    }
    .watermark{
      text-align:center;
      color:#7a7a7a;
      font-size:12px;
      margin-top:14px;
    }

    .tracker{
      margin-top:14px;
      border:1px solid var(--border);
      border-radius:18px;
      padding:14px;
      background:#fbfcff;
    }
    .tracker-row{
      display:grid;
      grid-template-columns:1fr 1fr;
      gap:10px;
      margin-top:10px;
    }

    .badge{
      display:inline-block;
      border-radius:999px;
      padding:6px 10px;
      font-size:12px;
      background:#eef2ff;
      border:1px solid #bfd0ff;
      margin-bottom:8px;
    }

    @media (max-width: 980px){
      .wrap{
        grid-template-columns:1fr;
      }
      .panel{
        order:2;
      }
      .preview-shell{
        order:1;
      }
    }
  </style>
</head>
<body>
  <div class="wrap">
    <div class="panel">
      <h1>Digital Business Card Builder</h1>
      <div class="sub">Basic includes QR, one action button, sponsor area, flipbook link, and 5 updates.</div>

      <div class="section">
        <h3>Card Settings</h3>
        <div class="grid-2">
          <div>
            <label class="label">Color Scheme</label>
            <select id="themeSelect">
              <option value="violet">Violet Blue</option>
              <option value="green">Green Dark</option>
              <option value="sunset">Sunset Orange</option>
              <option value="gold">Black Gold</option>
              <option value="clean">Clean Blue</option>
            </select>
          </div>
          <div>
            <label class="label">Font Style</label>
            <select id="fontSelect">
              <option value="inter">Inter</option>
              <option value="poppins">Poppins</option>
              <option value="montserrat">Montserrat</option>
              <option value="playfair">Playfair Display</option>
              <option value="roboto">Roboto</option>
            </select>
          </div>
        </div>

        <div class="grid-2">
          <div>
            <label class="label">Plan</label>
            <select id="planSelect">
              <option value="basic">Basic</option>
              <option value="upgrade">Upgrade</option>
            </select>
          </div>
          <div>
            <label class="label">Primary Action</label>
            <select id="actionType">
              <option value="call">Call</option>
              <option value="whatsapp">WhatsApp</option>
              <option value="email">Email</option>
              <option value="website">Website</option>
            </select>
          </div>
        </div>

        <label class="label">Updates Remaining</label>
        <input id="updatesLeft" type="text" value="5 / 5" />
      </div>

      <div class="section">
        <h3>Photo / Logo</h3>
        <div class="sub">Accepted: JPG, JPEG, PNG, WEBP • Recommended 800×800 • Max 2MB ideal</div>
        <input id="logoUpload" type="file" accept=".jpg,.jpeg,.png,.webp" />
      </div>

      <div class="section">
        <h3>Basic Information</h3>
        <label class="label">Full Name</label>
        <input id="fullName" type="text" value="Your Name" />

        <label class="label">Job Title</label>
        <input id="jobTitle" type="text" value="Your Job Title" />

        <label class="label">Company Name</label>
        <input id="companyName" type="text" value="Your Company" />
      </div>

      <div class="section">
        <h3>Contact Information</h3>
        <div class="grid-2">
          <div>
            <label class="label">Email</label>
            <input id="email" type="email" value="name@email.com" />
          </div>
          <div>
            <label class="label">Phone</label>
            <input id="phone" type="text" value="+59995120536" />
          </div>
        </div>

        <label class="label">Address</label>
        <input id="address" type="text" value="Your Address" />

        <label class="label">Website</label>
        <input id="website" type="text" value="https://example.com" />
      </div>

      <div class="section">
        <h3>Social Media</h3>
        <div class="grid-2">
          <div>
            <label class="label">Facebook</label>
            <input id="facebook" type="text" value="https://facebook.com/" />
          </div>
          <div>
            <label class="label">Instagram</label>
            <input id="instagram" type="text" value="https://instagram.com/" />
          </div>
        </div>
      </div>

      <div class="section">
        <h3>About & Services</h3>
        <label class="label">About</label>
        <textarea id="about">Add your bio here.</textarea>

        <label class="label">Services / Skills</label>
        <textarea id="services">Add your services here.</textarea>
      </div>

      <div class="section">
        <h3>Flipbook / Brochure</h3>
        <label class="label">PDF / Flipbook Link</label>
        <input id="flipbookLink" type="text" value="https://example.com/brochure.pdf" />
      </div>

      <div class="section">
        <h3>Sponsor Area</h3>
        <div class="sub">Optional monetization area. PracDi can receive a small portion of sponsor deals.</div>
        <label class="label">Sponsor Name</label>
        <input id="sponsorName" type="text" value="Sponsor Name" />

        <label class="label">Sponsor Link</label>
        <input id="sponsorLink" type="text" value="https://example.com" />

        <label class="label">Sponsor Logo</label>
        <input id="sponsorUpload" type="file" accept=".jpg,.jpeg,.png,.webp" />
      </div>

      <div class="section">
        <h3>Upgrade Tools</h3>
        <div class="grid-2">
          <div>
            <label class="label">NFC Enabled</label>
            <select id="nfcEnabled">
              <option value="no">No</option>
              <option value="yes">Yes</option>
            </select>
          </div>
          <div>
            <label class="label">vCard Enabled</label>
            <select id="vcardEnabled">
              <option value="no">No</option>
              <option value="yes">Yes</option>
            </select>
          </div>
        </div>

        <label class="label">YouTube / Video Link (upgrade)</label>
        <input id="videoLink" type="text" value="" placeholder="https://youtube.com/..." />
      </div>

      <div class="section">
        <div class="btn-row">
          <button class="btn btn-primary" onclick="applyChanges()">Save Changes</button>
          <button class="btn btn-light" onclick="resetForm()">Reset Form</button>
        </div>
      </div>
    </div>

    <div class="preview-shell" id="previewShell">
      <div class="preview-topbar">Preview</div>

      <div class="card-preview" id="cardPreview">
        <!-- Page 1 -->
        <div class="card-page active" id="page1">
          <div class="hero">
            <div class="logo-box" id="logoBox">
              Upload<br>Logo / Photo
            </div>
            <div class="title-box">
              <h2 id="pvName">Your Name</h2>
              <div class="job" id="pvJob">Your Job Title</div>
              <div class="company" id="pvCompany">Your Company</div>
            </div>
          </div>

          <div class="quick-grid">
            <div class="quick-box">
              <div style="font-size:12px;color:#66758a;margin-bottom:8px;">Quick Action</div>
              <a href="#" id="primaryActionBtn" class="quick-action">Call</a>
            </div>

            <div class="quick-box">
              <div class="qr-wrap">
                <div class="qr-box" id="qrcode"></div>
                <div style="font-size:12px;color:#66758a;">Scan full profile</div>
              </div>
            </div>
          </div>

          <a href="#" id="sponsorAnchor" target="_blank" style="text-decoration:none;color:inherit;">
            <div class="sponsor-box" id="sponsorBox">
              <div class="sponsor-logo" id="sponsorLogoBox">Sponsor</div>
              <div class="sponsor-text">
                <div id="pvSponsorName">Sponsor Name</div>
                <div style="font-size:12px;font-weight:400;">Sponsored placement</div>
              </div>
            </div>
          </a>

          <div class="watermark" id="watermark">Powered by PracDi</div>
        </div>

        <!-- Page 2 -->
        <div class="card-page" id="page2">
          <div class="page-head">Profile Info</div>
          <div class="info-list">
            <div class="info-item"><b>Name</b><span id="infoName">Your Name</span></div>
            <div class="info-item"><b>Address</b><span id="infoAddress">Your Address</span></div>
            <div class="info-item"><b>Email</b><span id="infoEmail">name@email.com</span></div>
            <div class="info-item"><b>Phone</b><span id="infoPhone">+59995120536</span></div>
            <div class="info-item"><b>Website</b><span id="infoWebsite">https://example.com</span></div>
            <div class="info-item"><b>Facebook</b><span id="infoFacebook">facebook</span></div>
            <div class="info-item"><b>Instagram</b><span id="infoInstagram">instagram</span></div>
            <div class="info-item"><b>About</b><span id="infoAbout">Add your bio here.</span></div>
            <div class="info-item"><b>Services</b><span id="infoServices">Add your services here.</span></div>
          </div>
        </div>

        <!-- Page 3 -->
        <div class="card-page" id="page3">
          <div class="page-head">Brochure & Upgrade Tools</div>

          <div class="flipbook-card">
            <div class="badge">Basic</div>
            <h3>3-Page Flipbook / Brochure</h3>
            <div class="flipbook-note">Upload externally, then link it here.</div>
            <a id="flipbookBtn" class="quick-action" target="_blank" href="#">View Brochure</a>
          </div>

          <div class="tracker" id="trackerBox" style="display:none;">
            <div class="badge">Upgrade</div>
            <h3 style="margin-bottom:8px;">Time Tracker</h3>
            <div id="trackerStatus">Status: Not running</div>
            <div id="trackerToday" style="margin-top:6px;">Today Total: 0h 0m</div>
            <div class="tracker-row">
              <button class="btn btn-primary" onclick="startWork()">Start Work</button>
              <button class="btn btn-light" onclick="stopWork()">Stop Work</button>
            </div>
          </div>

          <div class="tracker" id="upgradeInfoBox" style="display:none;">
            <div class="badge">Upgrade</div>
            <div><b>NFC:</b> <span id="showNfc">No</span></div>
            <div style="margin-top:6px;"><b>vCard:</b> <span id="showVcard">No</span></div>
            <div style="margin-top:6px;"><b>Video:</b> <a id="videoAnchor" href="#" target="_blank">Not set</a></div>
          </div>
        </div>

        <div class="nav">
          <button onclick="showPage(1)">Page 1</button>
          <button onclick="showPage(2)">Page 2</button>
          <button onclick="showPage(3)">Page 3</button>
        </div>
      </div>
    </div>
  </div>

  <script>
    let logoData = "";
    let sponsorData = "";
    let trackerStart = null;
    let trackerMinutesToday = 0;
    let qr = null;

    const themes = {
      violet: {
        previewBg: "linear-gradient(135deg,#6d7cff,#8f5cff)",
        heroGrad: "linear-gradient(135deg,#6d7cff,#8f5cff)",
        sponsorGrad: "linear-gradient(90deg,#ffb347,#ffd86f)"
      },
      green: {
        previewBg: "linear-gradient(135deg,#10b981,#0f172a)",
        heroGrad: "linear-gradient(135deg,#10b981,#0f172a)",
        sponsorGrad: "linear-gradient(90deg,#bbf7d0,#86efac)"
      },
      sunset: {
        previewBg: "linear-gradient(135deg,#ff7eb3,#ffd166)",
        heroGrad: "linear-gradient(135deg,#ff7eb3,#ffd166)",
        sponsorGrad: "linear-gradient(90deg,#f59e0b,#fde68a)"
      },
      gold: {
        previewBg: "linear-gradient(135deg,#111111,#d4af37)",
        heroGrad: "linear-gradient(135deg,#111111,#d4af37)",
        sponsorGrad: "linear-gradient(90deg,#9a6c00,#f7d76a)"
      },
      clean: {
        previewBg: "linear-gradient(135deg,#dbeafe,#93c5fd)",
        heroGrad: "linear-gradient(135deg,#2563eb,#60a5fa)",
        sponsorGrad: "linear-gradient(90deg,#dbeafe,#bfdbfe)"
      }
    };

    const fonts = {
      inter: "Inter, Arial, sans-serif",
      poppins: "Poppins, Arial, sans-serif",
      montserrat: "Montserrat, Arial, sans-serif",
      playfair: "'Playfair Display', serif",
      roboto: "Roboto, Arial, sans-serif"
    };

    function showPage(n){
      document.querySelectorAll(".card-page").forEach(p => p.classList.remove("active"));
      document.getElementById("page" + n).classList.add("active");
    }

    function fileToDataUrl(file, cb){
      if(!file) return;
      const reader = new FileReader();
      reader.onload = e => cb(e.target.result);
      reader.readAsDataURL(file);
    }

    document.getElementById("logoUpload").addEventListener("change", function(){
      fileToDataUrl(this.files[0], (data) => {
        logoData = data;
        applyChanges();
      });
    });

    document.getElementById("sponsorUpload").addEventListener("change", function(){
      fileToDataUrl(this.files[0], (data) => {
        sponsorData = data;
        applyChanges();
      });
    });

    function applyChanges(){
      const theme = document.getElementById("themeSelect").value;
      const font = document.getElementById("fontSelect").value;
      const plan = document.getElementById("planSelect").value;
      const actionType = document.getElementById("actionType").value;

      const fullName = document.getElementById("fullName").value || "Your Name";
      const jobTitle = document.getElementById("jobTitle").value || "Your Job Title";
      const companyName = document.getElementById("companyName").value || "Your Company";
      const email = document.getElementById("email").value || "";
      const phone = document.getElementById("phone").value || "";
      const address = document.getElementById("address").value || "";
      const website = document.getElementById("website").value || "";
      const facebook = document.getElementById("facebook").value || "";
      const instagram = document.getElementById("instagram").value || "";
      const about = document.getElementById("about").value || "";
      const services = document.getElementById("services").value || "";
      const flipbookLink = document.getElementById("flipbookLink").value || "#";
      const sponsorName = document.getElementById("sponsorName").value || "Sponsor Name";
      const sponsorLink = document.getElementById("sponsorLink").value || "#";
      const nfcEnabled = document.getElementById("nfcEnabled").value;
      const vcardEnabled = document.getElementById("vcardEnabled").value;
      const videoLink = document.getElementById("videoLink").value || "";

      document.body.style.fontFamily = fonts[font];
      document.querySelector(".panel").style.fontFamily = fonts[font];
      document.getElementById("cardPreview").style.fontFamily = fonts[font];
      document.getElementById("previewShell").style.background = themes[theme].previewBg;
      document.querySelector(".hero").style.background = themes[theme].heroGrad;
      document.getElementById("sponsorBox").style.background = themes[theme].sponsorGrad;

      document.getElementById("pvName").textContent = fullName;
      document.getElementById("pvJob").textContent = jobTitle;
      document.getElementById("pvCompany").textContent = companyName;

      document.getElementById("infoName").textContent = fullName;
      document.getElementById("infoAddress").textContent = address;
      document.getElementById("infoEmail").textContent = email;
      document.getElementById("infoPhone").textContent = phone;
      document.getElementById("infoWebsite").textContent = website;
      document.getElementById("infoFacebook").textContent = facebook;
      document.getElementById("infoInstagram").textContent = instagram;
      document.getElementById("infoAbout").textContent = about;
      document.getElementById("infoServices").textContent = services;

      if(logoData){
        document.getElementById("logoBox").innerHTML = `<img src="${logoData}" alt="logo">`;
      }

      if(sponsorData){
        document.getElementById("sponsorLogoBox").innerHTML = `<img src="${sponsorData}" alt="sponsor">`;
      } else {
        document.getElementById("sponsorLogoBox").textContent = "Sponsor";
      }

      document.getElementById("pvSponsorName").textContent = sponsorName;
      document.getElementById("sponsorAnchor").href = sponsorLink || "#";

      const actionBtn = document.getElementById("primaryActionBtn");
      if(actionType === "call"){
        actionBtn.textContent = "Call";
        actionBtn.href = "tel:" + phone;
      } else if(actionType === "whatsapp"){
        actionBtn.textContent = "WhatsApp";
        const waPhone = phone.replace(/[^\d]/g, "");
        actionBtn.href = "https://wa.me/" + waPhone;
      } else if(actionType === "email"){
        actionBtn.textContent = "Email";
        actionBtn.href = "mailto:" + email;
      } else {
        actionBtn.textContent = "Website";
        actionBtn.href = website || "#";
      }

      document.getElementById("flipbookBtn").href = flipbookLink;
      document.getElementById("showNfc").textContent = nfcEnabled === "yes" ? "Enabled" : "No";
      document.getElementById("showVcard").textContent = vcardEnabled === "yes" ? "Enabled" : "No";

      const videoAnchor = document.getElementById("videoAnchor");
      if(videoLink){
        videoAnchor.textContent = "Open Video";
        videoAnchor.href = videoLink;
      } else {
        videoAnchor.textContent = "Not set";
        videoAnchor.href = "#";
      }

      const basic = plan === "basic";
      document.getElementById("watermark").style.display = basic ? "block" : "none";
      document.getElementById("trackerBox").style.display = basic ? "none" : "block";
      document.getElementById("upgradeInfoBox").style.display = basic ? "none" : "block";

      buildQr(website || window.location.href);
    }

    function buildQr(text){
      const box = document.getElementById("qrcode");
      box.innerHTML = "";
      qr = new QRCode(box, {
        text: text,
        width: 80,
        height: 80
      });
    }

    function resetForm(){
      window.location.reload();
    }

    function startWork(){
      if(trackerStart) return;
      trackerStart = new Date();
      document.getElementById("trackerStatus").textContent = "Status: Running...";
    }

    function stopWork(){
      if(!trackerStart) return;
      const now = new Date();
      const minutes = Math.round((now - trackerStart) / 60000);
      trackerMinutesToday += minutes;
      trackerStart = null;
      const h = Math.floor(trackerMinutesToday / 60);
      const m = trackerMinutesToday % 60;
      document.getElementById("trackerStatus").textContent = "Status: Not running";
      document.getElementById("trackerToday").textContent = `Today Total: ${h}h ${m}m`;
    }

    applyChanges();
  </script>
</body>
</html>
